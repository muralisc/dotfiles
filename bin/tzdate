tzdate() {
    timestr=""
    tztime=""
    tztime=$(TZ="America/Los_Angeles" date -d "$1" "+ %H:%M PDT");
    timestr="$tztime"
    tztime=$(TZ="America/New_York" date -d "$1" "+ %H:%M NYC");
    timestr="$timestr /$tztime"
    tztime=$(TZ="Europe/London" date -d "$1" "+ %H:%M LON");
    timestr="$timestr /$tztime"
    if [[ $(uname -s) == "Darwin" ]] ; then
        echo "[$timestr]" | tee /dev/tty | pbcopy
    else
        echo "[$timestr]" | tee /dev/tty | xclip -i
    fi
}

