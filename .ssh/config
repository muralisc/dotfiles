Include config.d/*

Host *
    # Reuse connections
    ControlPath ~/.ssh/master-%r@%h:%p
    ControlMaster auto
    # Remote forward for https://github.com/wincent/clipper
    # This host runs clipper and needs the remote host to sent copy
    # data here
    RemoteForward 8377 localhost:8377
    LogLevel ERROR
    StrictHostKeyChecking no
    Compression yes
    ServerAliveInterval 60
    ServerAliveCountMax 30
    UserKnownHostsFile /dev/null
    ForwardAgent yes
